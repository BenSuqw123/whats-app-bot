# Group filter (keyword whitelist, comma-separated). Leave empty to collect ALL groups.
GROUP_KEYWORDS=sales,support,test

# Toggle chat types (set to 'false' to disable)
LISTEN_GROUPS=true
LISTEN_DMS=true
LISTEN_BROADCASTS=true

LOG_LEVEL=info

# Root folder for the unified archive (default: ./archive)
# Structure:
#   archive/
#     dms/<ChatName>/messages/YYYY-MM-DD.ndjson
#     dms/<ChatName>/images/
#     dms/<ChatName>/videos/
#     groups/<GroupName>/messages/YYYY-MM-DD.ndjson
#     groups/<GroupName>/images/
# ARCHIVE_BASE=./archive
